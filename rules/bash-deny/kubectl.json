{
  "deny-kubectl": {
    "description": "Blocks all kubectl invocations, including the bare kubectl command.",
    "hook": "tool_call",
    "filter": {
      "toolName": "bash"
    },
    "shell": "CMD=$(printf '%s' \"$PI_TOOL_INPUT\" | jq -r '.command // empty'); [ -z \"$CMD\" ] || bash-deny -r 'kubectl' -i \"$CMD\" -q"
  },
  "deny-k-alias": {
    "description": "Blocks the popular 'k' alias for kubectl — catches all 'k ...' invocations regardless of subcommand. Install separately from kubectl-* to guard the alias even when kubectl itself is allowed.",
    "hook": "tool_call",
    "filter": {
      "toolName": "bash"
    },
    "shell": "CMD=$(printf '%s' \"$PI_TOOL_INPUT\" | jq -r '.command // empty'); [ -z \"$CMD\" ] || bash-deny -r 'k' -i \"$CMD\" -q"
  },
  "deny-kubectl-exec": {
    "description": "Blocks running commands inside a pod (kubectl exec).",
    "hook": "tool_call",
    "filter": {
