{
  "deny-web-fetch": {
    "description": "Blocks network downloaders / web-fetch CLIs (curl, wget, aria2c, axel).",
    "hook": "tool_call",
    "filter": { "toolName": "bash" },
    "shell": "CMD=$(printf '%s' \"$PI_TOOL_INPUT\" | jq -r '.command // empty'); [ -z \"$CMD\" ] || bash-deny -r 'curl;wget;aria2c;axel' -i \"$CMD\" -q"
  }
}
