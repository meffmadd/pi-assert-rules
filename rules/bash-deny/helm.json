{
  "deny-helm-uninstall": {
    "description": "Blocks Helm release uninstallations.",
    "hook": "tool_call",
    "filter": {
      "toolName": "bash"
    },
    "shell": "CMD=$(printf '%s' \"$PI_TOOL_INPUT\" | jq -r '.command // empty'); [ -z \"$CMD\" ] || bash-deny -r 'helm uninstall' -i \"$CMD\" -q"
  },
  "deny-helm-install": {
    "description": "Blocks Helm release installations.",
    "hook": "tool_call",
    "filter": {
      "toolName": "bash"
    },
    "shell": "CMD=$(printf '%s' \"$PI_TOOL_INPUT\" | jq -r '.command // empty'); [ -z \"$CMD\" ] || bash-deny -r 'helm install' -i \"$CMD\" -q"
  },
  "deny-helm-upgrade": {
    "description": "Blocks Helm release upgrades.",
    "hook": "tool_call",
    "filter": {
      "toolName": "bash"
    },
    "shell": "CMD=$(printf '%s' \"$PI_TOOL_INPUT\" | jq -r '.command // empty'); [ -z \"$CMD\" ] || bash-deny -r 'helm upgrade' -i \"$CMD\" -q"
  },
  "deny-helm-rollback": {
    "description": "Blocks Helm release rollbacks.",
    "hook": "tool_call",
    "filter": {
      "toolName": "bash"
    },
    "shell": "CMD=$(printf '%s' \"$PI_TOOL_INPUT\" | jq -r '.command // empty'); [ -z \"$CMD\" ] || bash-deny -r 'helm rollback' -i \"$CMD\" -q"
  },
  "deny-helm-release-mgmt": {
    "description": "Blocks Helm release lifecycle changes: uninstall, install, upgrade, and rollback.",
    "preset": [
      "meffmadd/pi-assert-rules/deny-helm-uninstall",
      "meffmadd/pi-assert-rules/deny-helm-install",
      "meffmadd/pi-assert-rules/deny-helm-upgrade",
      "meffmadd/pi-assert-rules/deny-helm-rollback"
    ]
  },
  "deny-helm": {
    "description": "Blocks all Helm invocations, including the bare helm command.",
    "hook": "tool_call",
    "filter": {
      "toolName": "bash"
    },
    "shell": "CMD=$(printf '%s' \"$PI_TOOL_INPUT\" | jq -r '.command // empty'); [ -z \"$CMD\" ] || bash-deny -r 'helm' -i \"$CMD\" -q"
  },
  "deny-helm-plugin": {
    "description": "Blocks Helm plugin installs (helm plugin install).",
    "hook": "tool_call",
    "filter": {
      "toolName": "bash"
    },
    "shell": "CMD=$(printf '%s' \"$PI_TOOL_INPUT\" | jq -r '.command // empty'); [ -z \"$CMD\" ] || bash-deny -r 'helm plugin install' -i \"$CMD\" -q"
  }
}
